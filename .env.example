# Firebase web app config — copy to .env and fill with values from the Firebase console.
# All VITE_* vars are exposed to the client by Vite. Firebase web API keys are NOT secrets
# (they identify the project, not authorize access) — access control is enforced by
# Firestore/Storage security rules and App Check. Never put server-only secrets here.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: reCAPTCHA v3 site key for Firebase App Check (anti-abuse / rate limiting).
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Set to "true" to connect to local Firebase emulators during development.
VITE_USE_FIREBASE_EMULATORS=false
